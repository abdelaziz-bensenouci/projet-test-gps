{
  "expo": {
    "name": "Projet-test-gps",
    "slug": "Projet-test-gps",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "plugins": [
      "@maplibre/maplibre-react-native",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Autoriser Projet-test-gps a utiliser votre position."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Autoriser Projet-test-gps a utiliser votre position."
      }
    },
    "android": {
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "backgroundColor": "#ffffff",
      "display": "standalone",
      "favicon": "./assets/favicon.png",
      "lang": "fr",
      "name": "Projet-test-gps",
      "orientation": "portrait",
      "scope": "/",
      "startUrl": "/",
      "themeColor": "#111827",
      "shortName": "GPS"
    }
  }
}
